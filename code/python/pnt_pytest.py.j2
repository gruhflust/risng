import os
from datetime import datetime, timezone
from pathlib import Path

os.environ.setdefault("PYTHONPYCACHEPREFIX", str(Path.home() / ".cache" / "pycache"))

import pytest # type: ignore
import json
import subprocess
from pnt_tester import get_vlans_for_slots, run_ansible_playbook

DEVICE_NAME = "{{ device_name }}"
REMOTE_HOST = "{{ remote_host }}"
USERNAME = "{{ username }}"

@pytest.fixture
def fetch_network_data():
    """Retrieve VLANs and NetBox interface names."""
    return get_vlans_for_slots(DEVICE_NAME)

def test_vlan_configuration(fetch_network_data):
    """Test VLAN configuration using Ansible."""
    networks = fetch_network_data

    if not networks:
        pytest.fail("No VLANs found for testing.")

    # Run the playbook
    result = run_ansible_playbook(REMOTE_HOST, USERNAME, networks)

    # Load detected Linux interfaces from Ansible output
    try:
        with open("detected_interfaces.json", "r") as f:
            detected_interfaces = json.load(f)
    except FileNotFoundError:
        pytest.fail("Error: Detected interfaces file not found!")

    # Map NetBox interfaces to detected Linux interfaces
    for i, network in enumerate(networks):
        if i < len(detected_interfaces):
            network["linux_interface"] = detected_interfaces[i]

    # Process and display results
    print("\n--- TEST RESULTS ---")
    summary = []
    for entry in result["test_results"]:
        netbox_interface = entry["netbox_interface"]  # Use NetBox interface name (slotX-X)
        linux_interface = entry.get("linux_interface", "N/A")  # Detected Linux interface (ensX)
        vlan_id = entry["vlan_id"]
        gateway = entry["gateway"]

        # Determine test result
        success = (entry["status"] == "PASS")
        error_msg = entry["ping_output"] if not success else ""

        summary.append({
            "netbox_interface": netbox_interface,  # NetBox interface (slotX-X)
            "linux_interface": linux_interface,  # Detected Linux interface (ensX)
            "vlan_id": vlan_id,
            "gateway": gateway,
            "status": "PASS" if success else "FAIL",
            "error": error_msg
        })

        # Print result
        print(f"NetBox Interface: {netbox_interface} | Linux Interface: {linux_interface} | "
              f"VLAN: {vlan_id} | Gateway: {gateway} | "
              f"Result: {'PASS' if success else 'FAIL'}")

    # Save results to JSON
    with open("test_results.json", "w") as f:
        timestamp = datetime.now(timezone.utc).isoformat()
        f.write(f"# [{timestamp} UTC] generated by risng\n")
        json.dump(summary, f, indent=4)

    # Assert that at least one VLAN test passed
    assert any(entry["status"] == "PASS" for entry in summary), "All VLAN tests failed."
