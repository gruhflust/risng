#!/usr/bin/env bash
set -euo pipefail

ROOT="{{ risng_repo_root }}"
UPSTREAM_BASE="{{ risng_repo_upstream_baseurl }}"
SPEC_ROOT="{{ spec_repo_root }}"
EXTRA_ROOT="{{ pxe_tftp_dir }}/kickstart/repos"
LOGDIR="${ROOT}/sync/log"
mkdir -p "$LOGDIR" "$EXTRA_ROOT"
LOGFILE="$LOGDIR/last-sync.log"
exec > >(tee -a "$LOGFILE") 2>&1

echo "[$(date -Is)] RISng repo sync started"
echo "upstream=${UPSTREAM_BASE}"

sync_tree() {
  local source_url="$1"
  local target_dir="$2"
  mkdir -p "$target_dir"
  rm -rf "$target_dir"/*
  wget \
    --recursive \
    --no-parent \
    --no-host-directories \
    --cut-dirs=0 \
    --reject "index.html*" \
    --directory-prefix "$target_dir" \
    "$source_url/"
}

sync_tree "${UPSTREAM_BASE%/}/{{ risng_repo_centos_os_path }}" "$SPEC_ROOT"

for extra_repo in {% for repo in risng_repo_additional_repos %}{{ repo | to_json }} {% endfor %}; do
  sync_tree "${UPSTREAM_BASE%/}/${extra_repo}" "$EXTRA_ROOT/${extra_repo}"
done

if command -v createrepo_c >/dev/null 2>&1; then
  if find "$SPEC_ROOT" -type f -name '*.rpm' | grep -q .; then
    createrepo_c --update "$SPEC_ROOT" || true
  fi
fi

echo "[$(date -Is)] RISng repo sync finished"
