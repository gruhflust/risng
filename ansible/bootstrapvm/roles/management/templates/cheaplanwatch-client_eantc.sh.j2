#!/usr/bin/env bash
set -euo pipefail

# cheaplanwatch_eantc runtime client
# Parallel variant of cheaplanwatch-client.sh to keep legacy behavior unchanged.
# Default IMIX sizes are set to the EANTC IMIX with jumbo-frame mix.

SERVER_IP="${CHEAPLANWATCH_SERVER_IP:-10.228.229.7}"
# If CHEAPLANWATCH_SERVER_PORT is not provided, auto-discover in preferred order.
SERVER_PORT="${CHEAPLANWATCH_SERVER_PORT:-auto}"
INTERVAL="${CHEAPLANWATCH_INTERVAL:-2}"
MODE="${CHEAPLANWATCH_MODE:-imix}"   # live|imix (default imix for EANTC)

# EANTC IMIX mix (from botbrain traffic-mix-eanc.png): use discrete msg_size weights.
IMIX_SIZES_RAW="${CHEAPLANWATCH_IMIX_SIZES:-60:60:*5243,132:132:*861,296:296:*273,468:468:*233,557:557:*230,952:952:*127,1010:1010:*151,1500:1500:*2882,8800:8800:*2}"

REPORT_BANNER="risng - Cloud Host Endpoint Analysis Probe"
CHEAPLANWATCH_CLIENT_VERSION="{{ cheaplanwatch_client_version }}-eantc"
RUN_TS="${CHEAPLANWATCH_RUN_ID:-$(date +%Y%m%dT%H%M%S)}"
HOST_SHORT="$(hostname -s 2>/dev/null || hostname)"
OUT_BASE="${CHEAPLANWATCH_OUT_BASE:-/tmp/cheaplanwatch}"
JSON_OUT="${OUT_BASE}/${RUN_TS}-${HOST_SHORT}.json"
SAMPLES_NDJSON="${OUT_BASE}/${RUN_TS}-${HOST_SHORT}.samples.ndjson"

mkdir -p "${OUT_BASE}"

need_cmd() { command -v "$1" >/dev/null 2>&1 || { echo "Fehlt: $1"; exit 1; }; }
need_cmd qperf
need_cmd ping

has_iperf3=0
command -v iperf3 >/dev/null 2>&1 && has_iperf3=1

qperf_metric() {
  awk '{for(i=1;i<=NF;i++) if($i ~ /^[0-9]+(\.[0-9]+)?$/){u=(i<NF?$(i+1):""); print $i (u?" "u:""); exit}}'
}

qperf_unit() {
  awk '{if(NF>=2){print $2}else{print "qperf-unit"}}'
}

run_qperf_test() {
  local test_name="${1:?missing test name}"
  local imix_size="${2:-}"
  if [ "$MODE" = "imix" ] && [ -n "$imix_size" ]; then
    qperf -lp "$SERVER_PORT" "$SERVER_IP" "$test_name" -oo "msg_size:${imix_size}" 2>/dev/null || true
  else
    qperf -lp "$SERVER_PORT" "$SERVER_IP" "$test_name" 2>/dev/null || true
  fi
}

if [ "$MODE" != "live" ] && [ "$MODE" != "imix" ]; then
  echo "ERROR: invalid CHEAPLANWATCH_MODE=${MODE} (expected live|imix)"
  exit 3
fi

resolve_server_port() {
  # Prefer explicit env. If not set, probe eantc then legacy port.
  if [ "$SERVER_PORT" != "auto" ] && [ -n "$SERVER_PORT" ]; then
    printf '%s' "$SERVER_PORT"
    return 0
  fi

  local p
  for p in 19777 19765; do
    if qperf -lp "$p" "$SERVER_IP" tcp_bw >/dev/null 2>&1; then
      printf '%s' "$p"
      return 0
    fi
  done
  return 1
}

if ! SERVER_PORT="$(resolve_server_port)"; then
  echo "ERROR: cheaplanwatch server component is not reachable at ${SERVER_IP}:19777 (eantc) nor ${SERVER_IP}:19765 (legacy)."
  echo "Hint: Start it on risng with 'cheaplanwatchserver_eantc' (preferred) or legacy 'cheaplanwatchserver' and retry."
  echo "      You can also force a port: CHEAPLANWATCH_SERVER_PORT=19777 cheaplanwatch_eantc"
  exit 2
fi

baseline_tcp_bw_raw="$(run_qperf_test tcp_bw "${IMIX_SIZES_RAW%%,*}")"
baseline_tcp_lat_raw="$(run_qperf_test tcp_lat "${IMIX_SIZES_RAW%%,*}")"
baseline_tcp_bw="$(printf '%s\n' "$baseline_tcp_bw_raw" | qperf_metric)"
baseline_tcp_lat="$(printf '%s\n' "$baseline_tcp_lat_raw" | qperf_metric)"

baseline_iperf=""
if [ "$has_iperf3" -eq 1 ]; then
  baseline_iperf="$(iperf3 -c "$SERVER_IP" -t 5 2>/dev/null | awk '/receiver$/ {print $(NF-2) " " $(NF-1); exit}' || true)"
fi
[ -z "${baseline_iperf}" ] && baseline_iperf="n/a (iperf3 server not reachable?)"

ping_line="$(ping -c 8 "$SERVER_IP" 2>/dev/null | awk -F'=' '/rtt|round-trip/ {print $2}' | tr -d ' ' || true)"
base_ping_avg="$(printf '%s' "$ping_line" | cut -d/ -f2)"
base_ping_jitter="$(printf '%s' "$ping_line" | cut -d/ -f4)"
if ping -M do -s 1472 -c 1 "$SERVER_IP" >/dev/null 2>&1; then mtu_status="ok"; else mtu_status="failed"; fi

{% raw %}
IFS=',' read -r -a IMIX_SIZES <<< "${IMIX_SIZES_RAW}"
[ "${#IMIX_SIZES[@]}" -eq 0 ] && IMIX_SIZES=("60:60:*1")
imix_idx=0
{% endraw %}

: > "$SAMPLES_NDJSON"

write_json() {
python3 - <<'PY' "$SAMPLES_NDJSON" "$JSON_OUT" "$RUN_TS" "$HOST_SHORT" "$SERVER_IP" "$SERVER_PORT" "$baseline_tcp_bw" "$baseline_tcp_lat" "$baseline_iperf" "$base_ping_avg" "$base_ping_jitter" "$mtu_status" "$REPORT_BANNER" "$MODE" "$IMIX_SIZES_RAW"
import json, pathlib, sys, datetime
samples_path, json_out, run_ts, host_short, server_ip, server_port, b_bw, b_lat, b_iperf, b_avg, b_jit, mtu, banner, mode, imix_sizes = sys.argv[1:]
samples=[]
sp=pathlib.Path(samples_path)
if sp.exists():
    for line in sp.read_text(encoding='utf-8').splitlines():
        line=line.strip()
        if line:
            samples.append(json.loads(line))
obj={
  'report_banner': banner,
  'note': 'EANTC traffic mix enabled',
  'client_version': '{{ cheaplanwatch_client_version }}-eantc',
  'run_id': run_ts,
  'mode': mode,
  'imix_sizes': imix_sizes,
  'host': host_short,
  'address': '',
  'server_ip': server_ip,
  'server_port': server_port,
  'baseline': {
    'captured_at_iso': datetime.datetime.utcnow().isoformat(timespec='milliseconds') + 'Z',
    'mtu1500': mtu,
    'tcp_bw': b_bw,
    'tcp_lat': b_lat,
    'iperf_bw': b_iperf,
    'ping_avg': b_avg,
    'ping_jitter': b_jit,
  },
  'samples': samples,
}
pathlib.Path(json_out).write_text(json.dumps(obj, indent=2), encoding='utf-8')
PY
}

cleanup() { write_json || true; }
trap cleanup EXIT INT TERM

while true; do
  ts="$(date +%s)"
  ts_iso="$(date -u +%Y-%m-%dT%H:%M:%S.%3NZ)"

  active_imix_size=""
  if [ "$MODE" = "imix" ]; then
    active_imix_size="${IMIX_SIZES[$imix_idx]}"
{% raw %}
    imix_idx=$(( (imix_idx + 1) % ${#IMIX_SIZES[@]} ))
{% endraw %}
  fi

  tcp_bw="$(run_qperf_test tcp_bw "$active_imix_size" | qperf_metric || true)"
  tcp_lat="$(run_qperf_test tcp_lat "$active_imix_size" | qperf_metric || true)"
  pline="$(ping -c 4 "$SERVER_IP" 2>/dev/null | awk -F'=' '/rtt|round-trip/ {print $2}' | tr -d ' ' || true)"
  pavg="$(printf '%s' "$pline" | cut -d/ -f2)"
  pjit="$(printf '%s' "$pline" | cut -d/ -f4)"

  printf '{"ts_epoch":%s,"ts_iso":"%s","mode":"%s","imix_msg_size":"%s","tcp_bw":"%s","tcp_lat":"%s","ping_avg":"%s","ping_jitter":"%s"}\n' \
    "$ts" "$ts_iso" "$MODE" "$active_imix_size" "$tcp_bw" "$tcp_lat" "$pavg" "$pjit" >> "$SAMPLES_NDJSON"
  write_json

  bw_unit="$(printf '%s\n%s\n' "${tcp_bw:-}" "${baseline_tcp_bw:-}" | qperf_unit | head -n1)"
  lat_unit="$(printf '%s\n%s\n' "${tcp_lat:-}" "${baseline_tcp_lat:-}" | qperf_unit | head -n1)"

  clear
  echo "${REPORT_BANNER}"
  echo "cheaplanwatch_eantc v${CHEAPLANWATCH_CLIENT_VERSION} | $(date '+%F %T') | host=${HOST_SHORT} -> server=${SERVER_IP}:${SERVER_PORT}"
  echo "mode=${MODE}${active_imix_size:+ | imix_msg_size=${active_imix_size}}"
  echo
  echo "=== BASELINE ==="
  echo "MTU1500: ${mtu_status} | qperf_bw=${baseline_tcp_bw:-n/a} | qperf_lat=${baseline_tcp_lat:-n/a} | iperf=${baseline_iperf:-n/a}"
  echo "PING avg/jitter: ${base_ping_avg:-n/a}/${base_ping_jitter:-n/a}"
  echo
  echo "=== LIVE (last 10) ==="
  printf "%-18s | %-18s | %-16s | %-12s | %-12s\n" "tcp_bw" "tcp_lat" "imix_msg_size" "ping_avg" "ping_jitter"
  printf "%-18s | %-18s | %-16s | %-12s | %-12s\n" "(${bw_unit})" "(${lat_unit})" "(qperf -oo msg_size)" "(ms)" "(ms mdev)"
  python3 - <<'PY' "$SAMPLES_NDJSON"
import json, sys
p=sys.argv[1]
rows=[]
with open(p, 'r', encoding='utf-8') as f:
    for line in f:
        line=line.strip()
        if not line:
            continue
        try:
            rows.append(json.loads(line))
        except Exception:
            pass
for r in rows[-10:]:
    print(f"{str(r.get('tcp_bw',''))[:18]:18} | {str(r.get('tcp_lat',''))[:18]:18} | {str(r.get('imix_msg_size',''))[:16]:16} | {str(r.get('ping_avg',''))[:12]:12} | {str(r.get('ping_jitter',''))[:12]:12}")
PY

  if read -r -s -n 1 -t 0.15 _k; then
    break
  fi
  sleep "$INTERVAL"
done
