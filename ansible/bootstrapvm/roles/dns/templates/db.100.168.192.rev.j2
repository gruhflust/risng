$TTL 604800
{% set dns_host_octet = (dns_bootstrap_ip.split('.')[-1]) %}
@   IN  SOA  {{ dns_zone_name }}. admin.{{ dns_zone_name }}. (
                {{ serial | default('2025012101') }} ; Serial
                604800     ; Refresh
                86400      ; Retry
                2419200    ; Expire
                604800 )   ; Negative Cache TTL

@   IN  NS  bootstrapvm.{{ dns_zone_name }}.

{{ dns_host_octet }} IN  PTR  bootstrapvm.{{ dns_zone_name }}.