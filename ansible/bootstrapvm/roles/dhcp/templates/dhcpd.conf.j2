option arch code 93 = unsigned integer 16;

subnet {{ dhcp_subnet }} netmask {{ dhcp_netmask }} {
  range  {{ dhcp_range_start }} {{ dhcp_range_end }};
  option routers           {{ dhcp_gateway }};
  option broadcast-address {{ dhcp_subnet | regex_replace('0$', '255') }};
  option domain-name-servers {{ dhcp_dns_server }};
  next-server {{ dhcp_gateway }};
  include "/etc/dhcp/static-hosts.conf";
  
  # UEFI PXE: 00:07 PC-EFI x86-64
  #           00:08 EFI BC (Linux x86-64)
  #           00:09 EFI HTTP
  if option arch = 00:07 or option arch = 00:08 or option arch = 00:09 {
    filename "{{ dhcp_boot_profiles[dhcp_default_boot_profile].uefi }}";
  } else {
    filename "{{ dhcp_boot_profiles[dhcp_default_boot_profile].bios }}";
  }
}
