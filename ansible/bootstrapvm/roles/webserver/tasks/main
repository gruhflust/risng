---
# webserver_tasks_v3 – install lightweight Flask web UI system-wide

- name: 01 Install system packages
  apt:
    name:
      - python3
      - python3-flask
    state: present
    update_cache: true

- name: 01a Stop and disable legacy pntviewer service if present
  systemd:
    name: pntviewer
    enabled: false
    state: stopped
    daemon_reload: true
  failed_when: false

- name: 02 Ensure web UI directory exists
  file:
    path: /opt/risng-webui
    state: directory
    mode: '0755'

- name: 03 Deploy Flask app
  copy:
    dest: /opt/risng-webui/report_viewer.py
    mode: '0755'
    content: "{{ lookup('template', 'report_viewer.py.j2') }}"

- name: 04 Deploy systemd unit
  copy:
    dest: /etc/systemd/system/risng-webui.service
    content: |
      [Unit]
      Description=RISng Web UI
      After=network.target

      [Service]
      ExecStart=/usr/bin/python3 /opt/risng-webui/report_viewer.py
      WorkingDirectory=/opt/risng-webui
      Restart=always

      [Install]
      WantedBy=multi-user.target

- name: 05 Enable and start RISng web UI service
  systemd:
    name: risng-webui
    enabled: true
    state: started
    daemon_reload: true
