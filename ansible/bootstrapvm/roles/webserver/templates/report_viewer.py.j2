    mac = request.form.get('mac', '').strip().lower()
    if not re.match(r'^[0-9a-f]{2}(:[0-9a-f]{2}){5}$', mac):
        return 'invalid mac', 400
    delete_host_records(mac)
    run_apply_async()
    return redirect('/')


@app.route('/forget_host', methods=['POST'])
def forget_host():
    mac = request.form.get('mac', '').strip().lower()
    if not re.match(r'^[0-9a-f]{2}(:[0-9a-f]{2}){5}$', mac):
        return 'invalid mac', 400
    forget_host_records(mac)
    run_apply_async()
    return redirect('/')


@app.route('/reboot', methods=['POST'])
def reboot_host():
    ip = request.form.get('runtime_ip', '').strip() or request.form.get('ip', '').strip()
    request_reboot_best_effort(ip)
    return redirect('/')


@app.route('/assign_deploy', methods=['POST'])
def assign_deploy():
    mac = request.form.get('mac', '').strip().lower()
    role = request.form.get('role', '').strip()
    ip = request.form.get('ip', '').strip()
    runtime_ip = request.form.get('runtime_ip', '').strip()
    name = request.form.get('name', '').strip() or f"auto-{mac.replace(':','-')}"
    enable_secondstage = request.form.get('secondstage_enabled', 'on') == 'on'

    if ip and not re.match(r'^\d{1,3}(?:\.\d{1,3}){3}$', ip):
        return 'invalid ip', 400
    if not re.match(r'^[0-9a-f]{2}(:[0-9a-f]{2}){5}$', mac):
        return 'invalid mac', 400
    if role not in ROLES:
        return 'invalid role', 400

    m = load_map(); m[mac] = {'role': role, 'ip': ip, 'name': name}; save_map(m)
    s2 = load_secondstage_targets()
    s2[mac] = {
        'name': name,
        'mac': mac,
        'ip': ip,
        'boot_profile': role,
        'secondstage_enabled': bool(enable_secondstage and role != 'live-ris'),
        'secondstage_components': DEFAULT_COMPONENTS,
        'updated_at': now_iso(),
    }
    save_secondstage_targets(s2)

    run_assign_deploy_async(mac, ip)
    request_reboot_best_effort(runtime_ip or ip)
    return redirect('/')


