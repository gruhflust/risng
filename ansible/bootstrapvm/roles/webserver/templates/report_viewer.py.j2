  tr.status-deployable td:first-child { background: #0b5ed7; color: #fff; font-weight: 700; }
  tr.status-assigned td:first-child { background: #b39ddb; color: #000; font-weight: 600; }
  tr.status-boot_local_set td:first-child { background: #ffe08a; color: #000; font-weight: 700; }
</style>
<table border="1" cellpadding="6" cellspacing="0">
<tr><th>Status</th><th>MAC</th><th>Runtime IP</th><th>Assigned IP</th><th>Hostname</th><th>Role</th><th>SecondStage</th><th>HW Info</th><th>Assign/Update</th><th>Actions</th></tr>
{% for r in rows %}
<tr class="status-{{ r.status | lower }}">
  <td>{{ r.status }}</td>
  <td>{{ r.mac }}</td>
  <td>{{ r.runtime_ip }}</td>
  <td>{{ r.ip }}</td>
  <td>{{ r.hostname }}</td>
  <td>{{ r.role }}</td>
  <td>{{ 'on' if r.secondstage_enabled else 'off' }}</td>
  <td>
    CPU: {{ r.hw.get('cpu','n/a') }}<br>
    RAM: {{ r.hw.get('ram','n/a') }}<br>
    Disk: {{ r.hw.get('disk','n/a') }}
  </td>
  <td>
    <form action="/assign" method="post">
      <input type="hidden" name="mac" value="{{ r.mac }}"/>
      <input type="text" name="ip" value="{{ r.ip }}" size="13"/>
      <input type="hidden" name="runtime_ip" value="{{ r.runtime_ip }}"/>
      <input type="text" name="name" value="{{ r.hostname }}" size="14"/>
      <select name="role">
        {% for role in roles %}
        <option value="{{ role }}" {% if r.role == role %}selected{% endif %}>{{ role }}</option>
        {% endfor %}
      </select>
      <label><input type="checkbox" name="secondstage_enabled" {% if r.secondstage_enabled %}checked{% endif %}/> secondstage</label>
      <button type="submit">Assign + Apply</button>
      <button formaction="/assign_deploy" formmethod="post" type="submit">Assign + Deploy</button>
    </form>
  </td>
  <td>
    <form action="/set_boot" method="post" style="margin-bottom:4px;">
      <input type="hidden" name="mac" value="{{ r.mac }}"/>
      <input type="hidden" name="ip" value="{{ r.ip }}"/>
      <input type="hidden" name="runtime_ip" value="{{ r.runtime_ip }}"/>
      <input type="hidden" name="name" value="{{ r.hostname }}"/>
      <input type="hidden" name="role_hint" value="{{ r.role if r.role else 'iCMD' }}"/>
      <button name="mode" value="pxe" type="submit">Set PXE</button>
      <button name="mode" value="localdisk" type="submit">Set Local Disk</button>
    </form>
    <form action="/reboot" method="post" style="display:inline;">
      <input type="hidden" name="ip" value="{{ r.ip }}"/>
      <input type="hidden" name="runtime_ip" value="{{ r.runtime_ip }}"/>
      <button type="submit">Reboot</button>
    </form>
    <form action="/delete_host" method="post" style="display:inline;" onsubmit="return confirm('Delete assignment only?');">
      <input type="hidden" name="mac" value="{{ r.mac }}"/>
      <button type="submit">Delete Assignment</button>
    </form>
    <form action="/forget_host" method="post" style="display:inline;" onsubmit="return confirm('Forget host completely? It will disappear from leased/discovery and must rediscover on next boot.');">
      <input type="hidden" name="mac" value="{{ r.mac }}"/>
      <button type="submit">Forget Host</button>
    </form>
  </td>
</tr>
{% endfor %}
</table>
</body></html>
{% endraw %}"""

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=8089)
