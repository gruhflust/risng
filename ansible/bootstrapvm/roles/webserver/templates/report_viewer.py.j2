from flask import Flask, render_template_string, request, redirect, jsonify
import json
import re
import subprocess
import os
import time
import socket
from pathlib import Path
from datetime import datetime, timezone

app = Flask(__name__)

LEASES_FILES = [Path('/var/lib/dhcp/dhcpd.leases'), Path('/var/lib/dhcp/dhcpd.leases~')]
MAP_FILE = Path('/etc/risng/mac_role_map.json')
DISCOVERY_DIR = Path('/var/lib/tftpboot/runtime/discovery')
SECONDSTAGE_TARGETS_FILE = Path('/etc/risng/secondstage_targets.json')
STATIC_HOSTS_FILE = Path('/etc/dhcp/static-hosts.conf')
FORGOTTEN_HOSTS_FILE = Path('/var/lib/tftpboot/runtime/forgotten_hosts.json')
NGINX_ACCESS_LOG = Path('/var/log/nginx/risng-pxe.access.log')
STATE_FILE = Path('/var/lib/tftpboot/runtime/webui_state.json')
DEPLOY_STATE_FILE = Path('/var/lib/tftpboot/runtime/deploy_state.json')
MANAGEMENT_STATE_FILE = Path('/var/lib/tftpboot/runtime/management_state.json')
LOG_DIR = Path('/var/lib/tftpboot/runtime/webui_logs')
VALIDATION_SUMMARY = Path('{{ ssh_user_home }}/risdeploy-validation-summary.json')

PLAYBOOK_ROOT_CANDIDATES = [
    '{{ ssh_user_home }}/risng/ansible',
    '{{ ssh_user_home }}/botrepo/risng/ansible',
    '/home/risng/risng/ansible',
]

ROLES = ["iCWP", "iFDO", "iCMD", "FDPS", "CORRP", "live-ris", "localdisk"]
DEFAULT_COMPONENTS = ["graphics-gnome", "common-linux-monitoring-base"]
AUTO_LOCALBOOT_ON_SUCCESS = True


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def load_json(path: Path, default):
    if path.exists():
        try:
            return json.loads(path.read_text())
        except Exception:
            return default
    return default


def save_json(path: Path, data):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2, sort_keys=True))


def load_map():
    return load_json(MAP_FILE, {})


def save_map(data):
    save_json(MAP_FILE, data)


def load_secondstage_targets():
    return load_json(SECONDSTAGE_TARGETS_FILE, {})


def save_secondstage_targets(data):
    save_json(SECONDSTAGE_TARGETS_FILE, data)


def load_management_state():
    data = load_json(MANAGEMENT_STATE_FILE, {})
    return data if isinstance(data, dict) else {}


def save_management_state(data):
    save_json(MANAGEMENT_STATE_FILE, data if isinstance(data, dict) else {})


def update_management_state(mac: str, **fields):
    state = load_management_state()
    current = state.get(mac, {}) if isinstance(state.get(mac, {}), dict) else {}
    current.update({k: v for k, v in fields.items() if v is not None})
    current['mac'] = mac
    current['last_seen'] = now_iso()
    state[mac] = current
    save_management_state(state)
    return current


def load_deploy_state():
    data = load_json(DEPLOY_STATE_FILE, {})
    return data if isinstance(data, dict) else {}


def save_deploy_state(data):
    save_json(DEPLOY_STATE_FILE, data if isinstance(data, dict) else {})


def load_forgotten_hosts():
    data = load_json(FORGOTTEN_HOSTS_FILE, [])
    if isinstance(data, list):
        return set(str(x).lower() for x in data if isinstance(x, str))
    return set()


def save_forgotten_hosts(items):
    save_json(FORGOTTEN_HOSTS_FILE, sorted(set(str(x).lower() for x in items)))


def resolve_ansible_root() -> Path:
    for root in PLAYBOOK_ROOT_CANDIDATES:
        rp = Path(root)
        if rp.exists() and (rp / 'ansible.cfg').exists() and (rp / 'inventory/hosts.yml').exists():
            return rp
    return Path(PLAYBOOK_ROOT_CANDIDATES[0])


def ansible_cmd(playbook_rel: str) -> tuple[str, str]:
    root = resolve_ansible_root()
    cfg = root / 'ansible.cfg'
    inv = root / 'inventory/hosts.yml'
    pb = root / playbook_rel
    cmd = f"ANSIBLE_CONFIG={cfg} ansible-playbook -i {inv} {pb}"
    return cmd, str(root)


def launch_job(job_name: str, command: str, context: dict | None = None, cwd: str | None = None):
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    log_path = LOG_DIR / f"{job_name}-{int(time.time())}.log"
    with open(log_path, 'ab') as lf:
        proc = subprocess.Popen(
            ['bash', '-lc', command],
            cwd=cwd or os.getcwd(),
            stdout=lf,
            stderr=lf,
            env={**os.environ, 'HOME': '{{ ssh_user_home }}'},
        )
    state = load_json(STATE_FILE, {})
    state['job'] = {
        'name': job_name,
        'pid': proc.pid,
        'started_at': now_iso(),
        'log_path': str(log_path),
        'status': 'RUNNING',
        'command': command,
        'context': context or {},
    }
    save_json(STATE_FILE, state)


def load_validation_index():
    data = load_json(VALIDATION_SUMMARY, {})
    out = {}
    for h in data.get('hosts', []):
        ip = h.get('ip', '')
        if ip:
            out[ip] = bool(h.get('overall_ok'))
    return out


def refresh_job_state():
    state = load_json(STATE_FILE, {})
    job = state.get('job')
    if not job:
        return state
    pid = int(job.get('pid', 0) or 0)
    if pid > 0:
        try:
            os.kill(pid, 0)
            job['status'] = 'RUNNING'
        except OSError:
            if job.get('status') == 'RUNNING':
                job['status'] = 'FINISHED'
                job['finished_at'] = now_iso()

    # post-process assign+deploy -> localdisk after successful validation
    ctx = job.get('context', {}) if isinstance(job.get('context', {}), dict) else {}
    if AUTO_LOCALBOOT_ON_SUCCESS and job.get('name') == 'assign-deploy' and job.get('status') == 'FINISHED' and not ctx.get('post_processed'):
        ip = ctx.get('target_ip', '')
        mac = ctx.get('target_mac', '')
        if ip and mac and load_validation_index().get(ip):
            m = load_map()
            if mac in m:
                m[mac]['role'] = 'localdisk'
                save_map(m)
                update_cmd, root = ansible_cmd('bootstrapvm/update-dhcp-hosts.yml')
                launch_job('post-deploy-localboot', update_cmd, {'target_ip': ip, 'target_mac': mac}, cwd=root)
        ctx['post_processed'] = True
        job['context'] = ctx

    state['job'] = job
    save_json(STATE_FILE, state)
    return state


def request_reboot_best_effort(ip: str):
    if not ip:
        return
    base_cmd, root = ansible_cmd('secondstage/trigger-reboot.yml')
    # credential fallback for different client phases
    variants = [
        f"{base_cmd} -e target_ip={ip} -e reboot_user=root -e reboot_ssh_key_file={{ ssh_user_home }}/.ssh/id_ed25519",
    ]
    cmd = " || ".join(variants)
    launch_job('reboot', cmd, {'target_ip': ip}, cwd=root)


def run_apply_async():
    update_cmd, root = ansible_cmd('bootstrapvm/update-dhcp-hosts.yml')
    launch_job('assign-apply', update_cmd, cwd=root)


def run_assign_deploy_async(target_mac: str, target_ip: str):
    update_cmd, root = ansible_cmd('bootstrapvm/update-dhcp-hosts.yml')
    deploy_cmd, _ = ansible_cmd('secondstage/risdeploy.yml')
    validate_cmd, _ = ansible_cmd('secondstage/risdeploy-validation.yml')
    deploy_state = load_deploy_state()
    deploy_state[target_mac] = 'DEPLOYING'
    save_deploy_state(deploy_state)
    cmd = f"{update_cmd} && {deploy_cmd} -e risdeploy_target_mac={target_mac} && {validate_cmd} -e risdeploy_validation_target_mac={target_mac}"
    launch_job('assign-deploy', cmd, {'target_mac': target_mac, 'target_ip': target_ip, 'post_processed': False}, cwd=root)


def delete_host_records(mac: str):
    m = load_map()
    if mac in m:
        del m[mac]
        save_map(m)
    s2 = load_secondstage_targets()
    if mac in s2:
        del s2[mac]
        save_secondstage_targets(s2)
    forgotten = load_forgotten_hosts()
    if mac in forgotten:
        forgotten.remove(mac)
        save_forgotten_hosts(forgotten)
    d = DISCOVERY_DIR / f"{mac}.json"
    if d.exists():
        d.unlink()


def forget_host_records(mac: str):
    delete_host_records(mac)
    forgotten = load_forgotten_hosts()
    forgotten.add(mac)
    save_forgotten_hosts(forgotten)


def parse_static_hosts():
    items = {}
    if not STATIC_HOSTS_FILE.exists():
        return items
    current = {}
    for raw in STATIC_HOSTS_FILE.read_text(errors='ignore').splitlines():
        line = raw.strip()
        if line.startswith('host ') and line.endswith('{'):
            current = {'name': line.split()[1]}
            continue
        if line.startswith('hardware ethernet '):
            current['mac'] = line.split()[2].rstrip(';').lower()
            continue
        if line.startswith('fixed-address '):
            current['ip'] = line.split()[1].rstrip(';')
            continue
        if line == '}':
            mac = current.get('mac')
            if mac:
                items[mac] = {'mac': mac, 'ip': current.get('ip', ''), 'hostname': current.get('name', '')}
            current = {}
    return items


def parse_leases():
    items = {}
    lease_re = re.compile(r'^lease\s+([0-9.]+)\s+\{')
    mac_re = re.compile(r'^hardware\s+ethernet\s+([0-9a-f:]{17});', re.IGNORECASE)
    host_re = re.compile(r'^client-hostname\s+"(.*)";')

    for lf in LEASES_FILES:
        if not lf.exists():
            continue
        current = {}
        for raw in lf.read_text(errors='ignore').splitlines():
            line = raw.strip()
            m = lease_re.match(line)
            if m:
                current = {'ip': m.group(1)}
                continue
            m = mac_re.match(line)
            if m:
                current['mac'] = m.group(1).lower()
                continue
            m = host_re.match(line)
            if m:
                current['hostname'] = m.group(1)
                continue
            if line == '}':
                mac = current.get('mac')
                if mac:
                    items[mac] = {'mac': mac, 'ip': current.get('ip', ''), 'hostname': current.get('hostname', '')}
                current = {}
    return sorted(items.values(), key=lambda x: x.get('mac', ''))


def load_discovery(mac):
    p = DISCOVERY_DIR / f"{mac}.json"
    if not p.exists():
        return {}
    try:
        return json.loads(p.read_text())
    except Exception:
        return {}


def list_discovery_files():
    DISCOVERY_DIR.mkdir(parents=True, exist_ok=True)
    out = []
    for p in sorted(DISCOVERY_DIR.glob('*.json')):
        mac = p.stem.lower()
        if not re.match(r'^[0-9a-f]{2}(:[0-9a-f]{2}){5}$', mac):
            continue
        out.append({'mac': mac, 'hw': load_discovery(mac)})
    return out


def parse_install_progress_ips():
    progress = {}
    if not NGINX_ACCESS_LOG.exists():
        return progress
    lines = NGINX_ACCESS_LOG.read_text(errors='ignore').splitlines()[-2000:]
    for ln in lines:
        parts = ln.split(' ', 3)
        if len(parts) < 4:
            continue
        ip = parts[0]
        if '/kickstart/' in ln:
            progress[ip] = 'INSTALL_RUNNING'
        elif '/centos/7/os/x86_64/' in ln and progress.get(ip) != 'INSTALL_RUNNING':
            progress[ip] = 'STAGE2_FETCH'
    return progress


def infer_role_from_hostname(hostname: str) -> str:
    h = (hostname or '').lower()
    if 'cmd' in h:
        return 'iCMD'
    if 'cwp' in h:
        return 'iCWP'
    if 'fdo' in h:
        return 'iFDO'
    if 'fdps' in h:
        return 'FDPS'
    if 'corrp' in h:
        return 'CORRP'
    return 'iCWP'


def ssh_reachable(ip: str, timeout: float = 0.35) -> bool:
    if not ip:
        return False
    try:
        with socket.create_connection((ip, 22), timeout=timeout):
            return True
    except Exception:
        return False


@app.route('/api/discovery', methods=['POST'])
def api_discovery():
    payload = request.get_json(silent=True) or {}
    mac = str(payload.get('mac', '')).strip().lower()
    if not re.match(r'^[0-9a-f]{2}(:[0-9a-f]{2}){5}$', mac):
        return jsonify({'ok': False, 'error': 'invalid mac'}), 400
    hw = payload.get('hardware', {}) if isinstance(payload.get('hardware', {}), dict) else {}
    record = {
        'mac': mac,
        'hostname': payload.get('hostname', ''),
        'ip': payload.get('ip', ''),
        'timestamp': now_iso(),
        'hardware': hw,
    }
    DISCOVERY_DIR.mkdir(parents=True, exist_ok=True)
    (DISCOVERY_DIR / f"{mac}.json").write_text(json.dumps(record, indent=2, sort_keys=True))
    update_management_state(mac, runtime_ip=record.get('ip',''), last_runtime_ip=record.get('ip',''), phase='DISCOVERED')
    return jsonify({'ok': True, 'mac': mac})


@app.route('/')
def index():
    role_map = load_map()
    secondstage = load_secondstage_targets()
    forgotten = load_forgotten_hosts()
    leases = {l['mac']: l for l in parse_leases() if l.get('mac', '').lower() not in forgotten}
    static_hosts = {k: v for k, v in parse_static_hosts().items() if k.lower() not in forgotten}
    progress = parse_install_progress_ips()
    validation_index = load_validation_index()
    deploy_state = load_deploy_state()
    management_state = load_management_state()
    state = refresh_job_state()

    known_macs = set(leases.keys()) | set(static_hosts.keys()) | set(role_map.keys()) | set(secondstage.keys())
    for d in list_discovery_files():
        known_macs.add(d['mac'])

    rows = []
    for mac in sorted(known_macs):
        lease = leases.get(mac, {})
        stat = static_hosts.get(mac, {})
        meta = role_map.get(mac, {})
        s2 = secondstage.get(mac, {})
        d = load_discovery(mac)

        mgmt = management_state.get(mac, {}) if isinstance(management_state.get(mac, {}), dict) else {}
        runtime_ip = lease.get('ip', '') or mgmt.get('runtime_ip', '') or stat.get('ip', '')
        assigned_ip = meta.get('ip') or s2.get('ip', '') or mgmt.get('assigned_ip', '')
        ip = assigned_ip or runtime_ip
        update_management_state(mac, runtime_ip=runtime_ip or None, assigned_ip=assigned_ip or None, name=(meta.get('name') or s2.get('name') or lease.get('hostname','') or stat.get('hostname','') or mgmt.get('name') or None), role=(meta.get('role') or s2.get('boot_profile') or mgmt.get('role') or None))
        role_eff = meta.get('role') or s2.get('boot_profile') or infer_role_from_hostname(meta.get('name') or s2.get('name') or lease.get('hostname','') or stat.get('hostname',''))

        status = 'ASSIGNED' if mac in role_map else ('DISCOVERED' if d else ('LEASED' if mac in leases else 'CONFIGURED'))
        reachable_now = ssh_reachable(runtime_ip or ip)
        if (meta.get('role') == 'localdisk' or s2.get('boot_profile') == 'localdisk') and ip and validation_index.get(ip):
            status = 'BOOT_LOCAL_SET'
        elif ip and validation_index.get(ip):
            status = 'INSTALLED'
        elif deploy_state.get(mac) == 'DEPLOYING':
            status = 'DEPLOYING'
        elif assigned_ip and reachable_now:
            status = 'DEPLOYABLE'
        elif reachable_now:
            status = 'MANAGABLE'
        elif runtime_ip and runtime_ip in progress:
            status = progress[runtime_ip]

        rows.append({
            'mac': mac,
            'ip': ip,
            'runtime_ip': runtime_ip,
            'hostname': meta.get('name') or s2.get('name') or lease.get('hostname','') or stat.get('hostname',''),
            'role': role_eff,
            'secondstage_enabled': bool(s2.get('secondstage_enabled')),
            'components': ','.join(s2.get('secondstage_components', [])) if isinstance(s2.get('secondstage_components', []), list) else '',
            'hw': d.get('hardware', d if isinstance(d, dict) else {}),
            'status': status,
        })

    known_ips = {r['runtime_ip'] or r['ip'] for r in rows if (r.get('runtime_ip') or r.get('ip'))}
    for ip, st in progress.items():
        if ip in known_ips:
            continue
        rows.append({'mac': 'n/a', 'ip': ip, 'runtime_ip': ip, 'hostname': '', 'role': '', 'secondstage_enabled': False, 'components': '', 'hw': {}, 'status': st})

    diagnostics = {
        'lease_files': [str(p) for p in LEASES_FILES if p.exists()],
        'lease_count': len(leases),
        'static_host_count': len(static_hosts),
        'discovery_count': len(list_discovery_files()),
        'mapped_count': len(role_map),
    }
    return render_template_string(TEMPLATE, rows=rows, roles=ROLES, diagnostics=diagnostics, job=state.get('job', {}))


@app.route('/set_boot', methods=['POST'])
def set_boot():
    mac = request.form.get('mac', '').strip().lower()
    mode = request.form.get('mode', '').strip().lower()
    ip = request.form.get('ip', '').strip()
    runtime_ip = request.form.get('runtime_ip', '').strip()
    name = request.form.get('name', '').strip() or f"auto-{mac.replace(':','-')}"
    role_hint = request.form.get('role_hint', '').strip() or 'iCMD'

    if not re.match(r'^[0-9a-f]{2}(:[0-9a-f]{2}){5}$', mac):
        return 'invalid mac', 400
    if mode not in ('pxe', 'localdisk'):
        return 'invalid mode', 400

    role = 'localdisk' if mode == 'localdisk' else role_hint
    if role not in ROLES:
        role = 'iCMD'

    m = load_map(); m[mac] = {'role': role, 'ip': ip, 'name': name}; save_map(m)
    update_management_state(mac, assigned_ip=ip or None, name=name, role=role, phase='DEPLOYING')
    update_management_state(mac, assigned_ip=ip or None, name=name, role=role, phase='ASSIGNED')
    s2 = load_secondstage_targets()
    cur = s2.get(mac, {})
    s2[mac] = {
        'name': name,
        'mac': mac,
        'ip': ip,
        'boot_profile': role,
        'secondstage_enabled': bool(cur.get('secondstage_enabled', role != 'live-ris')),
        'secondstage_components': cur.get('secondstage_components', DEFAULT_COMPONENTS),
        'updated_at': now_iso(),
    }
    save_secondstage_targets(s2)

    run_apply_async()
    return redirect('/')


@app.route('/delete_host', methods=['POST'])
